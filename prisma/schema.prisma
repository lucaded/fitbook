generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth required models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// App models
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  phone         String?
  role          Role      @default(CLIENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  bookings Booking[]
  clients  Client[]
  profile  ClientProfile?
}

enum Role {
  ADMIN    // Antonio (trainer)
  CLIENT   // Clients
}

// Trainer manages clients directly (no login needed for clients)
model Client {
  id        String   @id @default(cuid())
  trainerId String?
  name      String
  email     String?
  phone     String?
  height    Float?   // cm
  weight    Float?   // kg
  goals     String?  @db.Text
  injuries  String?  @db.Text
  notes     String?  @db.Text
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainer   User?    @relation(fields: [trainerId], references: [id], onDelete: SetNull)
  programs  ClientProgram[]
  bookings  Booking[]
  prs       PersonalRecord[]
}

model ClientProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  height    Float?   // cm
  weight    Float?   // kg
  goals     String?  @db.Text
  injuries  String?  @db.Text
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Program assigned to a client by the trainer
model ClientProgram {
  id                  String   @id @default(cuid())
  clientId            String
  name                String
  daysPerWeek         Int
  progressionIncrement Float  @default(2.5) // kg
  oneRMs              Json     @default("{}") // exerciseId → kg
  status              ProgramStatus @default(ACTIVE)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  client Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  weeks  ProgramWeek[]
}

enum ProgramStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

model ProgramWeek {
  id          String   @id @default(cuid())
  programId   String
  weekNumber  Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  program ClientProgram  @relation(fields: [programId], references: [id], onDelete: Cascade)
  days    ProgramDay[]
}

model ProgramDay {
  id        String   @id @default(cuid())
  weekId    String
  dayNumber Int
  label     String?  // e.g., "Upper A", "Lower B"

  week      ProgramWeek        @relation(fields: [weekId], references: [id], onDelete: Cascade)
  exercises ProgramExercise[]
}

model ProgramExercise {
  id               String  @id @default(cuid())
  dayId            String
  exerciseName     String
  exerciseId       String  // library reference
  order            Int     @default(0)
  sets             Int
  reps             Int
  intensityPercent Float?  // %1RM
  loadKg           Float?  // prescribed kg
  rpe              Float?  // optional
  notes            String? @db.Text
  // Actuals logged by trainer
  actualSets       Int?
  actualReps       Int?
  actualLoadKg     Float?

  day ProgramDay @relation(fields: [dayId], references: [id], onDelete: Cascade)
}

model PersonalRecord {
  id           String   @id @default(cuid())
  clientId     String
  exerciseId   String
  exerciseName String
  loadKg       Float
  reps         Int
  date         DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Booking {
  id        String        @id @default(cuid())
  userId    String?
  clientId  String?
  date      DateTime
  startTime DateTime
  endTime   DateTime
  type      SessionType
  status    BookingStatus @default(PENDING)
  notes     String?       @db.Text
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user     User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  client   Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  training TrainingSession?
}

enum SessionType {
  PERSONAL
  GROUP
  ONLINE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model TrainingSession {
  id        String   @id @default(cuid())
  bookingId String   @unique
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  booking   Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  exercises Exercise[]
}

model Exercise {
  id                String @id @default(cuid())
  trainingSessionId String
  name              String
  sets              Int?
  reps              Int?
  weight            Float? // kg
  duration          Int?   // seconds
  restTime          Int?   // seconds
  notes             String? @db.Text
  order             Int     @default(0)

  trainingSession TrainingSession @relation(fields: [trainingSessionId], references: [id], onDelete: Cascade)
}
